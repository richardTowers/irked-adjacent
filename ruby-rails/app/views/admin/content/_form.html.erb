<% errors = @version&.errors || ActiveModel::Errors.new(@version || Version.new) %>
<% node_errors = @node&.errors || ActiveModel::Errors.new(@node || Node.new) %>
<% all_errors = [] %>
<% errors.full_messages.each { |m| all_errors << m } %>
<% node_errors.full_messages.each { |m| all_errors << m } %>

<% if all_errors.any? %>
  <div role="alert">
    <h2><%= pluralize(all_errors.count, "error") %> prohibited this node from being saved:</h2>
    <ul>
      <% all_errors.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<form action="<%= url %>" method="post">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
  <% if method == :patch %>
    <input type="hidden" name="_method" value="patch">
  <% end %>

  <div>
    <label for="node_title">Title</label>
    <input type="text" name="node[title]" id="node_title" value="<%= @version&.title %>"
           required="required"
           <%= errors[:title].any? ? "aria-invalid=\"true\" aria-describedby=\"title-error\"".html_safe : "" %>>
    <% if errors[:title].any? %>
      <span id="title-error"><%= errors[:title].join(", ") %></span>
    <% end %>
  </div>

  <% if local_assigns[:show_slug_field] %>
    <div>
      <label for="node_slug">Slug</label>
      <input type="text" name="node[slug]" id="node_slug" value="<%= @node&.slug %>"
             <%= node_errors[:slug].any? ? "aria-invalid=\"true\" aria-describedby=\"slug-error\"".html_safe : "" %>>
      <% if node_errors[:slug].any? %>
        <span id="slug-error"><%= node_errors[:slug].join(", ") %></span>
      <% end %>
    </div>
  <% end %>

  <div>
    <label for="node_body">Body</label>
    <textarea name="node[body]" id="node_body"><%= @version&.body %></textarea>
  </div>

  <div>
    <input type="submit" value="<%= submit_label %>">
    <%= link_to "Cancel", cancel_path %>
  </div>
</form>
