<% if local_assigns[:show_team_selector] %>
  <%# Separate form for no-JS content type selection (must be OUTSIDE the main form to avoid nested forms) %>
  <form action="<%= new_admin_content_path %>" method="get" id="content-type-selector"></form>
<% end %>

<% if @node.errors.any? %>
  <div role="alert">
    <h2><%= pluralize(@node.errors.count, "error") %> prohibited this node from being saved:</h2>
    <ul>
      <% @node.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: @node, url: url) do |form| %>
  <% if local_assigns[:show_team_selector] %>
    <div>
      <%= form.label :team_id, "Team" %>
      <%= form.collection_select :team_id, @user_teams.order(:name), :id, :name,
            { prompt: "Select a team" },
            **(@node.errors[:team_id].any? ? { "aria-invalid": "true", "aria-describedby": "team-id-error" } : {}) %>
      <% if @node.errors[:team_id].any? %>
        <span id="team-id-error"><%= @node.errors[:team_id].join(", ") %></span>
      <% end %>
    </div>
  <% end %>

  <% if local_assigns[:show_team_selector] %>
    <%# New node: content type selector with no-JS reload %>
    <div>
      <%= label_tag :content_type_id, "Content type" %>
      <% content_types = ContentType.where(team: @user_teams).order(:name) %>
      <%# This select is inside the main form for display; a duplicate targets the external form for no-JS %>
      <%= select_tag :content_type_id,
            options_from_collection_for_select(content_types, :id, :name, @node.content_type_id),
            prompt: "Select a content type",
            id: "content_type_id" %>
      <noscript>
        <%# Duplicate select associated with the external GET form for no-JS content type switching %>
        <select name="content_type_id" form="content-type-selector" aria-label="Content type">
          <option value="">Select a content type</option>
          <% content_types.each do |ct| %>
            <option value="<%= ct.id %>" <%= "selected" if ct.id == @node.content_type_id %>><%= ct.name %></option>
          <% end %>
        </select>
        <button type="submit" form="content-type-selector">Load fields</button>
      </noscript>
    </div>

    <%# Auto-reload with JS when content type changes %>
    <script>
      document.getElementById("content_type_id").addEventListener("change", function() {
        var ctId = this.value;
        if (ctId) {
          window.location.href = "<%= new_admin_content_path %>" + "?content_type_id=" + encodeURIComponent(ctId);
        }
      });
    </script>

    <%= form.hidden_field :content_type_id %>
  <% else %>
    <%# Edit node: show content type name, not editable %>
    <div>
      <strong>Content type:</strong> <span><%= @node.content_type&.name %></span>
    </div>
  <% end %>

  <div>
    <%= form.label :title %>
    <%= form.text_field :title,
          required: true,
          **(@node.errors[:title].any? ? { "aria-invalid": "true", "aria-describedby": "title-error" } : {}) %>
    <% if @node.errors[:title].any? %>
      <span id="title-error"><%= @node.errors[:title].join(", ") %></span>
    <% end %>
  </div>

  <div>
    <%= form.label :slug %>
    <%= form.text_field :slug,
          **(@node.errors[:slug].any? ? { "aria-invalid": "true", "aria-describedby": "slug-error" } : {}) %>
    <% if @node.errors[:slug].any? %>
      <span id="slug-error"><%= @node.errors[:slug].join(", ") %></span>
    <% end %>
  </div>

  <div>
    <%= form.check_box :published %>
    <%= form.label :published %>
  </div>

  <% if @field_definitions.present? %>
    <fieldset>
      <legend>Fields</legend>
      <% @field_definitions.each do |field_def| %>
        <%= render "admin/content/dynamic_field", form: form, field_def: field_def, node: @node, reference_nodes: @reference_nodes %>
      <% end %>
    </fieldset>
  <% end %>

  <div>
    <%= form.submit submit_label %>
    <%= link_to "Cancel", cancel_path %>
  </div>
<% end %>
