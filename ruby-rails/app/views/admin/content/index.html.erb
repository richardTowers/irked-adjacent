<h1>Nodes</h1>

<%= link_to "New Node", "/admin/content/new" %>

<% if @nodes.empty? %>
  <p>No nodes yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th scope="col">Title</th>
        <th scope="col">Slug</th>
        <th scope="col">Status</th>
        <th scope="col">Updated</th>
      </tr>
    </thead>
    <tbody>
      <% @nodes.each do |node| %>
        <% current_version = Version.current_for(node, @main_branch) %>
        <tr>
          <td><%= link_to current_version&.title, admin_content_path(node) %></td>
          <td><%= node.slug %></td>
          <td><%= current_version&.committed_at ? "Committed" : "Draft" %></td>
          <td><%= node.updated_at.strftime("%-d %B %Y %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
