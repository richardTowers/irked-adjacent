<h1><%= @team.name %></h1>

<dl>
  <dt>Name</dt>
  <dd><%= @team.name %></dd>

  <dt>Slug</dt>
  <dd><%= @team.slug %></dd>
</dl>

<h2>Members</h2>

<table>
  <thead>
    <tr>
      <th scope="col">Email</th>
      <th scope="col">Role</th>
      <th scope="col">Joined</th>
      <th scope="col">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @team.memberships.includes(:user).each do |membership| %>
      <tr>
        <td><%= membership.user.email_address %></td>
        <td>
          <%= form_with(url: admin_team_member_path(@team, membership), method: :patch) do |form| %>
            <%= form.label :role, "Role for #{membership.user.email_address}", class: "visually-hidden" %>
            <%= form.select :role, Membership::ROLES.map { |r| [r.capitalize, r] }, {}, onchange: "this.form.requestSubmit()" %>
            <noscript><%= form.submit "Update" %></noscript>
          <% end %>
        </td>
        <td><%= membership.created_at.strftime("%-d %B %Y") %></td>
        <td>
          <% if @team.memberships.count > 1 || membership.user != Current.user %>
            <%= button_to "Remove",
                  admin_team_member_path(@team, membership),
                  method: :delete,
                  aria: { label: "Remove #{membership.user.email_address}" },
                  data: { confirm: "Are you sure you want to remove this member?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Add Member</h2>

<%= form_with(url: admin_team_members_path(@team), method: :post) do |form| %>
  <div>
    <%= form.label :email_address, "Email address" %>
    <%= form.text_field :email_address, required: true %>
  </div>

  <fieldset>
    <legend>Role</legend>
    <div>
      <%= form.radio_button :role, "member", id: "role_member", checked: true %>
      <%= form.label :role_member, "Member" %>
      <span> — Can create and manage content.</span>
    </div>
    <div>
      <%= form.radio_button :role, "editor", id: "role_editor" %>
      <%= form.label :role_editor, "Editor" %>
      <span> — Can create and manage content, and configure content types.</span>
    </div>
  </fieldset>

  <div>
    <%= form.submit "Add Member" %>
  </div>
<% end %>

<p>
  <%= link_to "Edit Team", edit_admin_team_path(@team) %>
  <%= button_to "Delete Team", admin_team_path(@team), method: :delete, data: { confirm: "Are you sure you want to delete this team? This action cannot be undone." } %>
</p>
