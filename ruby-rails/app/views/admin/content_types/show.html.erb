<% content_for(:title) { "#{@content_type.name} — Content Types" } %>

<h1><%= @content_type.name %></h1>

<dl>
  <dt>Team</dt>
  <dd><%= @content_type.team.name %></dd>

  <dt>Slug</dt>
  <dd><%= @content_type.slug %></dd>

  <% if @content_type.description.present? %>
    <dt>Description</dt>
    <dd><%= @content_type.description %></dd>
  <% end %>

  <dt>Nodes</dt>
  <dd><%= @content_type.respond_to?(:nodes) ? @content_type.nodes.count : 0 %></dd>
</dl>

<p>
  <% if Current.user.editor_for?(@content_type.team) %>
    <%= link_to "Edit", edit_admin_content_type_path(@content_type.slug) %>
  <% end %>
  <%= link_to "Back to content types", admin_content_types_path %>
</p>

<% if Current.user.editor_for?(@content_type.team) %>
  <% has_nodes = @content_type.respond_to?(:nodes) && @content_type.nodes.any? %>
  <% unless has_nodes %>
    <%= button_to "Delete content type", admin_content_type_path(@content_type.slug), method: :delete, data: { confirm: "Are you sure you want to delete this content type? This action cannot be undone." } %>
  <% end %>
<% end %>

<h2>Field Definitions</h2>

<% is_editor = Current.user.editor_for?(@content_type.team) %>
<% fields = @content_type.field_definitions.order(:position) %>
<% if fields.any? %>
  <table>
    <thead>
      <tr>
        <% if is_editor %>
          <th scope="col">Position</th>
        <% end %>
        <th scope="col">Name</th>
        <th scope="col">API Key</th>
        <th scope="col">Type</th>
        <th scope="col">Required</th>
        <% if is_editor %>
          <th scope="col">Actions</th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% fields.each do |field| %>
        <tr id="field-<%= field.id %>">
          <% if is_editor %>
            <td>
              <%= form_with(model: field, url: admin_content_type_field_path(@content_type.slug, field), method: :patch) do |form| %>
                <%= form.number_field :position, value: field.position, min: 0, style: "width: 4em", aria: { label: "Position for #{field.name}" } %>
                <%= form.submit "Move", aria: { label: "Update position for #{field.name}" } %>
              <% end %>
            </td>
          <% end %>
          <td><%= field.name %></td>
          <td><code><%= field.api_key %></code></td>
          <td><%= field.field_type %></td>
          <td><%= field.required? ? "Yes" : "No" %></td>
          <% if is_editor %>
            <td>
              <%= link_to "Edit", edit_admin_content_type_path(@content_type.slug, anchor: "edit-field-#{field.id}") %>
              <%= button_to "Remove", admin_content_type_field_path(@content_type.slug, field), method: :delete, data: { confirm: "Are you sure you want to remove this field? Existing node data for this field will become orphaned (but not lost)." }, aria: { label: "Remove #{field.name}" } %>
            </td>
          <% end %>
        </tr>
        <% if is_editor && @editing_field&.id == field.id %>
          <tr id="edit-field-<%= field.id %>">
            <td colspan="6">
              <%= render "admin/content_types/field_form", field_definition: @editing_field, content_type: @content_type, url: admin_content_type_field_path(@content_type.slug, field), method: :patch, submit_label: "Update Field" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No fields defined yet.</p>
<% end %>

<% if is_editor %>
  <h3 id="add-field">Add Field</h3>

  <%= render "admin/content_types/field_form", field_definition: @field_definition_form || @content_type.field_definitions.build(position: fields.size), content_type: @content_type, url: admin_content_type_fields_path(@content_type.slug), method: :post, submit_label: "Add Field" %>
<% end %>
